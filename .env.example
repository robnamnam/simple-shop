# --- Stripe ---
# Get a test key from https://dashboard.stripe.com/test/apikeys
# Use a live key (sk_live_...) only in production.
STRIPE_SECRET_KEY=sk_test_replace_me

# Get this from `stripe listen --forward-to localhost:3000/api/stripe-webhook`
# (https://stripe.com/docs/webhooks). Optional in dev — without it, the server
# will still accept webhooks but skip signature verification.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# --- Admin ---
# Random string. Required to call /api/admin/* endpoints (e.g. restocking).
ADMIN_TOKEN=replace_me_with_a_long_random_string

# --- Server ---
PORT=3000
